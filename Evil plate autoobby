-- ─── PATHFIND ─────────────────────────────────────────────────────────────────
local function walkTo(target)
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return false end

    local path = PathfindingService:CreatePath({
        AgentHeight = 5, AgentRadius = 2,
        AgentCanJump = true, AgentCanClimb = true,
    })
    local ok = pcall(function() path:ComputeAsync(hrp.Position, target) end)

    if not ok or path.Status ~= Enum.PathStatus.Success then
        hum:MoveTo(target)
        local done = false
        hum.MoveToFinished:Connect(function() done = true end)
        local t = 0
        while not done and t < 15 do task.wait(0.1); t += 0.1 end
        return done
    end

    for _, wp in ipairs(path:GetWaypoints()) do
        if not isRunning then return false end
        if wp.Action == Enum.PathWaypointAction.Jump then hum.Jump = true end
        hum:MoveTo(wp.Position)
        local moved, conn = false, nil
        conn = hum.MoveToFinished:Connect(function() moved = true; conn:Disconnect() end)
        local t = 0
        while not moved and t < 4 do task.wait(0.1); t += 0.1 end
        if not moved then conn:Disconnect() end
    end
    return true
end

local function tweenTp(cf)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp  = char:WaitForChild("HumanoidRootPart")
    local tw   = TweenService:Create(hrp, TweenInfo.new(1.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = cf})
    tw:Play()
    task.wait(1.5)
end

-- Void-drop reset: fling character to void Y, wait for respawn
local function voidReset()
    local char = player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            -- Drop to void instantly
            hrp.CFrame = CFrame.new(hrp.Position.X, VOID_Y, hrp.Position.Z)
        end
    end
    -- Wait for character to die and respawn
    player.CharacterAdded:Wait()
    task.wait(1.2)
end

-- ─── MAIN CYCLE ───────────────────────────────────────────────────────────────
local function runCycle()
    updateManualBtn()

    -- 1. Walk to walk target
    timerLabel.Text = "~"
    timerLabel.TextColor3 = CYAN
    autoBtn.Text = "WALKING..."
    autoBtn.TextColor3 = CYAN
    setRing(0.4, CYAN)
    setDot(CYAN)

    local reached = walkTo(WALK_TARGET)
    if not isRunning then isRunning = false; updateManualBtn() return end

    if not reached then
        local char = player.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = CFrame.new(WALK_TARGET) end
        end
        task.wait(0.4)
    end
    if not isRunning then isRunning = false; updateManualBtn() return end

    -- 2. Tween teleport to tp target
    timerLabel.Text = "GO"
    timerLabel.TextColor3 = GREEN
    autoBtn.Text = "TELEPORTING"
    autoBtn.TextColor3 = GREEN
    setRing(1, GREEN)
    setDot(GREEN)
    tweenTp(TP_TARGET)
    if not isRunning then isRunning = false; updateManualBtn() return end

    -- 3. Void reset (instead of LoadCharacter)
    timerLabel.Text = "↓"
    timerLabel.TextColor3 = ORANGE
    autoBtn.Text = "RESETTING..."
    autoBtn.TextColor3 = ORANGE
    setRing(1, ORANGE)
    setDot(ORANGE)
    voidReset()

    -- 4. Post-cycle cleanup
    isRunning = false
    updateManualBtn()
    setDot(enabled and GREEN or DIM)
    setRing(0, BLUE)
    timerLabel.Text = enabled and tostring(COOLDOWN) or "--"
    timerLabel.TextColor3 = Color3.fromRGB(160, 160, 175)

    if enabled then
        timeLeft = COOLDOWN
        ready    = false
        autoBtn.Text      = string.format("AUTO  ON  —  %ds", COOLDOWN)
        autoBtn.TextColor3 = Color3.fromRGB(160, 160, 175)
    else
        autoBtn.Text       = "AUTO  OFF"
        autoBtn.TextColor3 = Color3.fromRGB(80, 80, 95)
    end
end

local function startCycle()
    if isRunning then return end
    isRunning = true
    ready     = false
    task.spawn(runCycle)
end

