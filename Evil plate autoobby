-- Countdown loop
task.spawn(function()
    while true do
        if enabled and not ready and not isRunning then
            if timeLeft <= 0 then
                ready = true
                timerLabel.Text = "!"
                timerLabel.TextColor3 = Color3.fromRGB(80, 200, 120)
                button.Text = "READY"
                button.TextColor3 = Color3.fromRGB(80, 200, 120)
                dot.BackgroundColor3 = Color3.fromRGB(80, 200, 120)
                setRingProgress(1, Color3.fromRGB(80, 200, 120))
                manualButton.Visible = true
                -- Auto-start the cycle immediately when ready
                startCycle()
            else
                local progress = 1 - (timeLeft / cooldown)
                local ringColor = timeLeft <= 10
                    and Color3.fromRGB(220, 140, 40)
                    or Color3.fromRGB(80, 122, 176)
                setRingProgress(progress, ringColor)
                timerLabel.Text = tostring(timeLeft)
                button.Text = string.format("ON  —  %ds", timeLeft)
                button.TextColor3 = Color3.fromRGB(170, 170, 180)
                timeLeft -= 1
            end
        elseif not enabled then
            button.Text = "OFF"
            button.TextColor3 = Color3.fromRGB(170, 170, 180)
        end
        task.wait(1)
    end
end)
