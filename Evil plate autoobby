-- ─── PATHFIND ────────────────────────────────────────────────────────────────
local function walkTo(target)
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return false end

    local path = PathfindingService:CreatePath({AgentHeight=5,AgentRadius=2,AgentCanJump=true,AgentCanClimb=true})
    local ok = pcall(function() path:ComputeAsync(hrp.Position, target) end)

    if not ok or path.Status ~= Enum.PathStatus.Success then
        hum:MoveTo(target)
        local done, t = false, 0
        hum.MoveToFinished:Connect(function() done = true end)
        while not done and t < 15 do task.wait(0.1); t += 0.1 end
        return done
    end

    for _, wp in ipairs(path:GetWaypoints()) do
        if not isRunning then return false end
        if wp.Action == Enum.PathWaypointAction.Jump then hum.Jump = true end
        hum:MoveTo(wp.Position)
        local moved, conn = false, nil
        conn = hum.MoveToFinished:Connect(function() moved=true; conn:Disconnect() end)
        local t = 0
        while not moved and t < 4 do task.wait(0.1); t += 0.1 end
        if not moved then conn:Disconnect() end
    end
    return true
end

local function tweenTp(cf)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    TweenService:Create(hrp, TweenInfo.new(1.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame=cf}):Play()
    task.wait(1.5)
end

local function voidReset()
    local char = player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = CFrame.new(hrp.Position.X, VOID_Y, hrp.Position.Z) end
    end
    player.CharacterAdded:Wait()
    task.wait(1.2)
end

-- ─── CYCLE ───────────────────────────────────────────────────────────────────
local function runCycle()
    refreshManBtn()

    -- Walk
    timerTxt.Text = "~"; timerTxt.TextColor3 = CYAN
    autoBtn.Text = "WALKING..."; autoBtn.TextColor3 = CYAN
    dot.BackgroundColor3 = CYAN; setRing(0.4, CYAN)

    local reached = walkTo(WALK_TARGET)
    if not isRunning then isRunning=false; refreshManBtn() return end
    if not reached then
        local c = player.Character
        if c then local h = c:FindFirstChild("HumanoidRootPart"); if h then h.CFrame = CFrame.new(WALK_TARGET) end end
        task.wait(0.3)
    end
    if not isRunning then isRunning=false; refreshManBtn() return end

    -- Teleport
    timerTxt.Text = "GO"; timerTxt.TextColor3 = GREEN
    autoBtn.Text = "TELEPORTING"; autoBtn.TextColor3 = GREEN
    dot.BackgroundColor3 = GREEN; setRing(1, GREEN)
    tweenTp(TP_TARGET)
    if not isRunning then isRunning=false; refreshManBtn() return end

    -- Void reset
    timerTxt.Text = "↓"; timerTxt.TextColor3 = ORANGE
    autoBtn.Text = "RESETTING..."; autoBtn.TextColor3 = ORANGE
    dot.BackgroundColor3 = ORANGE; setRing(1, ORANGE)
    voidReset()

    -- Done
    isRunning = false
    refreshManBtn()
    if enabled then
        timeLeft = COOLDOWN; ready = false
        dot.BackgroundColor3 = GREEN; setRing(0, BLUE)
        timerTxt.Text = tostring(COOLDOWN); timerTxt.TextColor3 = Color3.fromRGB(150,150,165)
        autoBtn.Text = string.format("AUTO  ON  —  %ds", COOLDOWN)
        autoBtn.TextColor3 = Color3.fromRGB(150,150,165)
    else
        dot.BackgroundColor3 = DIM; setRing(0, DIM)
        timerTxt.Text = "--"; timerTxt.TextColor3 = Color3.fromRGB(150,150,165)
        autoBtn.Text = "AUTO  OFF"; autoBtn.TextColor3 = Color3.fromRGB(72,72,88)
    end
end

local function startCycle()
    if isRunning then return end
    isRunning = true; ready = false
    task.spawn(runCycle)
end

