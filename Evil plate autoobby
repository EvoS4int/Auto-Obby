-- Dragging
local dragging, dragStart, startPos = false, nil, nil
frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Ring helper
local function setRingProgress(progress, color)
    ringFill.BackgroundColor3 = color
    ringGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, color),
        ColorSequenceKeypoint.new(math.clamp(progress - 0.001, 0, 1), color),
        ColorSequenceKeypoint.new(math.clamp(progress, 0.002, 1), Color3.fromRGB(28, 28, 32)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(28, 28, 32)),
    })
end

local function setStatus(ringText, ringColor, btnText, btnColor, ringProgress, ringFillColor)
    timerLabel.Text = ringText
    timerLabel.TextColor3 = ringColor
    button.Text = btnText
    button.TextColor3 = btnColor
    setRingProgress(ringProgress, ringFillColor)
end

-- Pathfind walk to a target, returns true if reached
local function walkToPosition(target)
    local character = player.Character
    if not character then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp then return false end

    local path = PathfindingService:CreatePath({
        AgentHeight = 5,
        AgentRadius = 2,
        AgentCanJump = true,
        AgentCanClimb = true,
    })

    local success = pcall(function()
        path:ComputeAsync(hrp.Position, target)
    end)

    if not success or path.Status ~= Enum.PathStatus.Success then
        humanoid:MoveTo(target)
        local finished = false
        humanoid.MoveToFinished:Connect(function() finished = true end)
        local t = 0
        while not finished and t < 15 do task.wait(0.1); t += 0.1 end
        return finished
    end

    local waypoints = path:GetWaypoints()
    for _, waypoint in ipairs(waypoints) do
        if not enabled then return false end
        if waypoint.Action == Enum.PathWaypointAction.Jump then
            humanoid.Jump = true
        end
        humanoid:MoveTo(waypoint.Position)
        local moved = false
        local conn
        conn = humanoid.MoveToFinished:Connect(function()
            moved = true
            conn:Disconnect()
        end)
        local t = 0
        while not moved and t < 4 do task.wait(0.1); t += 0.1 end
        if not moved then conn:Disconnect() end
    end
    return true
end

-- Tween teleport to a CFrame, returns after tween completes
local function tweenTeleport(cf)
    local character = player.Character or player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    local tween = TweenService:Create(hrp, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = cf})
    tween:Play()
    task.wait(1.6)
end

-- Full cycle: walk 117,15,150 → tween to 179,28,249 → reset → repeat
local function runCycle()
    -- Step 1: Pathfind walk to 117, 15, 150
    setStatus("~", Color3.fromRGB(100, 180, 255), "WALKING...", Color3.fromRGB(100, 180, 255), 0.5, Color3.fromRGB(100, 180, 255))
    dot.BackgroundColor3 = Color3.fromRGB(100, 180, 255)

    local reached = walkToPosition(walkTarget)
    if not enabled then isRunning = false return end

    if not reached then
        -- If pathfinding failed, force move directly
        local character = player.Character
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = CFrame.new(walkTarget) end
        end
        task.wait(0.5)
    end

    if not enabled then isRunning = false return end

    -- Step 2: Tween teleport to 179, 28, 249
    setStatus("GO", Color3.fromRGB(80, 200, 120), "TELEPORTING...", Color3.fromRGB(80, 200, 120), 1, Color3.fromRGB(80, 200, 120))
    dot.BackgroundColor3 = Color3.fromRGB(80, 200, 120)
    tweenTeleport(teleportTarget)

    if not enabled then isRunning = false return end

    -- Step 3: Reset character
    setStatus("R", Color3.fromRGB(220, 140, 40), "RESETTING...", Color3.fromRGB(220, 140, 40), 1, Color3.fromRGB(220, 140, 40))
    dot.BackgroundColor3 = Color3.fromRGB(220, 140, 40)
    player:LoadCharacter()
    player.CharacterAdded:Wait()
    task.wait(1.5)

    if not enabled then isRunning = false return end

    -- Step 4: Reset cooldown and loop
    timeLeft = cooldown
    ready = false
    isRunning = false
    dot.BackgroundColor3 = Color3.fromRGB(80, 200, 120)
    timerLabel.TextColor3 = Color3.fromRGB(170, 170, 180)
    timerLabel.Text = tostring(cooldown)
    button.TextColor3 = Color3.fromRGB(170, 170, 180)
    setRingProgress(0, Color3.fromRGB(80, 122, 176))
end

local function startCycle()
    if isRunning then return end
    isRunning = true
    ready = false
    manualButton.Visible = false
    task.spawn(runCycle)
end

