-- ─── COUNTDOWN LOOP ───────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        task.wait(1)
        if enabled and not ready and not isRunning then
            if timeLeft <= 0 then
                ready = true
                timerLabel.Text       = "!"
                timerLabel.TextColor3 = GREEN
                autoBtn.Text          = "READY"
                autoBtn.TextColor3    = GREEN
                setDot(GREEN)
                setRing(1, GREEN)
                startCycle()
            else
                local prog = 1 - (timeLeft / COOLDOWN)
                local col  = timeLeft <= 15 and ORANGE or BLUE
                setRing(prog, col)
                timerLabel.Text       = tostring(timeLeft)
                timerLabel.TextColor3 = Color3.fromRGB(160, 160, 175)
                autoBtn.Text          = string.format("AUTO  ON  —  %ds", timeLeft)
                autoBtn.TextColor3    = Color3.fromRGB(160, 160, 175)
                timeLeft -= 1
            end
        elseif not enabled and not isRunning then
            autoBtn.Text       = "AUTO  OFF"
            autoBtn.TextColor3 = Color3.fromRGB(80, 80, 95)
        end
    end
end)
