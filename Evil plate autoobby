-- ─── COUNTDOWN ───────────────────────────────────────────────────────────────
task.spawn(function()
    while task.wait(1) do
        if enabled and not ready and not isRunning then
            if timeLeft <= 0 then
                ready = true
                timerTxt.Text = "!"; timerTxt.TextColor3 = GREEN
                autoBtn.Text = "READY"; autoBtn.TextColor3 = GREEN
                dot.BackgroundColor3 = GREEN; setRing(1, GREEN)
                startCycle()
            else
                local prog = 1 - (timeLeft / COOLDOWN)
                local col  = timeLeft <= 15 and ORANGE or BLUE
                setRing(prog, col)
                timerTxt.Text = tostring(timeLeft)
                timerTxt.TextColor3 = Color3.fromRGB(150,150,165)
                autoBtn.Text = string.format("AUTO  ON  —  %ds", timeLeft)
                autoBtn.TextColor3 = Color3.fromRGB(150,150,165)
                timeLeft -= 1
            end
        elseif not enabled and not isRunning then
            autoBtn.Text = "AUTO  OFF"
            autoBtn.TextColor3 = Color3.fromRGB(72,72,88)
        end
    end
end)

