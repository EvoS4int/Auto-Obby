-- ─── RING HELPER ─────────────────────────────────────────────────────────────
local function setRing(p, c)
    ringFill.BackgroundColor3 = c
    ringGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0,                        c),
        ColorSequenceKeypoint.new(math.clamp(p-0.001,0,1),  c),
        ColorSequenceKeypoint.new(math.clamp(p, 0.002, 1),  TRBG),
        ColorSequenceKeypoint.new(1,                        TRBG),
    })
end

